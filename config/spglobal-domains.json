    {
      "name": "PASGlossary",
      "displayName": "PAS Glossary",
      "description": "Glossary for PAS domain — used for cross-domain isolation testing",
      "domain": "pas",
      "owner_team": "PASAdmins",
      "terms": [
        { "name": "PortfolioRisk",   "displayName": "Portfolio Risk",   "description": "Aggregate risk metric for a portfolio" },
        { "name": "ExposureLimit",   "displayName": "Exposure Limit",   "description": "Maximum allowed exposure to a single counterparty" }
      ]
    },
