{
  "description": "S&P Global — Domain-scoped 3-tier RBAC (read/write/admin per domain) on Collate 1.12.3",
  "omd_version": "1.12.3",
  "server": {
    "base_url": "http://localhost:8585/api/v1",
    "auth_type": "basic",
    "admin_email": "admin@open-metadata.org",
    "admin_password": "admin",
    "api_token": ""
  },

  "domains": [
    { "name": "marketimpact", "displayName": "Market Impact", "description": "Market Impact domain", "domainType": "Aggregate" },
    { "name": "pas",          "displayName": "PAS",           "description": "PAS domain",           "domainType": "Aggregate" },
    { "name": "tti",          "displayName": "TTI",           "description": "TTI domain",           "domainType": "Aggregate" },
    { "name": "playground",   "displayName": "Playground",    "description": "Playground / sandbox domain for experimentation", "domainType": "Aggregate" }
  ],

  "policies": [
    {
      "name": "DomainReadPolicy",
      "displayName": "Domain Read Policy",
      "description": "Base read-only access — ViewAll/ViewBasic on all resources. Assigned to every user as the default.",
      "rules": [
        {
          "name": "AllowViewAll",
          "description": "Allow viewing all resources",
          "effect": "allow",
          "operations": ["ViewAll", "ViewBasic", "ViewCustomFields"],
          "resources": ["All"]
        }
      ]
    },
    {
      "name": "DomainWritePolicy",
      "displayName": "Domain Write Policy",
      "description": "Write access scoped to the user's domain. Allows create/edit operations only when hasDomain() matches. Denies all writes outside the domain.",
      "rules": [
        {
          "name": "DenyWriteOutsideDomain",
          "description": "Deny all write operations when user is not in the resource's domain",
          "effect": "deny",
          "operations": [
            "Create", "Delete", "EditAll", "EditCustomFields",
            "EditDescription", "EditDisplayName", "EditOwners",
            "EditReviewers", "EditTags", "EditGlossaryTerms",
            "EditTier", "EditEntityRelationship", "EditLineage",
            "EditPolicy", "EditSampleData"
          ],
          "resources": ["All"],
          "condition": "!hasDomain()"
        },
        {
          "name": "AllowWriteInDomain",
          "description": "Allow create/edit operations within the user's domain",
          "effect": "allow",
          "operations": [
            "Create", "EditAll", "EditCustomFields",
            "EditDescription", "EditDisplayName", "EditOwners",
            "EditReviewers", "EditTags", "EditGlossaryTerms",
            "EditTier", "EditEntityRelationship", "EditLineage",
            "EditSampleData"
          ],
          "resources": ["All"],
          "condition": "hasDomain()"
        }
      ]
    },
    {
      "name": "DomainAdminPolicy",
      "displayName": "Domain Admin Policy",
      "description": "Full CRUD (including delete) scoped to the user's domain. Domain admins are super users within their domain but cannot touch other domains.",
      "rules": [
        {
          "name": "DenyAllOutsideDomain",
          "description": "Deny all write/delete operations outside the user's domain",
          "effect": "deny",
          "operations": [
            "Create", "Delete", "EditAll", "EditCustomFields",
            "EditDescription", "EditDisplayName", "EditOwners",
            "EditReviewers", "EditTags", "EditGlossaryTerms",
            "EditTier", "EditEntityRelationship", "EditLineage",
            "EditPolicy", "EditSampleData"
          ],
          "resources": ["All"],
          "condition": "!hasDomain()"
        },
        {
          "name": "AllowAllInDomain",
          "description": "Allow all operations within the user's domain (full CRUD including delete)",
          "effect": "allow",
          "operations": ["All"],
          "resources": ["All"],
          "condition": "hasDomain()"
        }
      ]
    }
  ],

  "roles": [
    {
      "name": "DomainReader",
      "description": "Read-only access to all data assets. Default role for all users (data consumers).",
      "policies": ["DomainReadPolicy"]
    },
    {
      "name": "DomainWriter",
      "description": "Read access everywhere + create/edit (no delete) within assigned domain.",
      "policies": ["DomainReadPolicy", "DomainWritePolicy"]
    },
    {
      "name": "DomainAdmin",
      "description": "Full CRUD within assigned domain. Super user for their domain only.",
      "policies": ["DomainReadPolicy", "DomainAdminPolicy"]
    }
  ],

