# OpenMetadata version — used by docker-compose
OMD_VERSION=1.11.7

# Override server URL (e.g. for Collate cloud)
# OMD_BASE_URL=https://your-org.getcollate.io/api/v1

# Auth: set ONE of these approaches
# Option 1: Basic auth (default for local Docker)
# OMD_AUTH_TYPE=basic
# OMD_ADMIN_EMAIL=admin@open-metadata.org
# OMD_ADMIN_PASSWORD=admin

# Option 2: API token (for Collate cloud or token-based setups)
# OMD_AUTH_TYPE=token
# OMD_API_TOKEN=your-jwt-or-api-token-here
