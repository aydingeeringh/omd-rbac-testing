      "domain": "playground",
      "terms": [
        { "name": "TestTerm", "displayName": "Test Term", "description": "A test term for sandbox experimentation" }
      ]
    }
  ],

  "test_matrix": [
    {
      "name": "MI Reader — can view MI glossary",
      "user": "mi-reader@spglobal-test.local",
      "resource_type": "glossary",
      "resource": "MarketImpactGlossary",
      "expect": {
        "ViewAll": "allow",
        "ViewBasic": "allow",
        "Create": "notAllow",
        "EditAll": "notAllow",
        "Delete": "notAllow",
        "EditDescription": "notAllow"
      }
    },
    {
      "name": "MI Writer — can create/edit in MI glossary (no delete)",
      "user": "mi-writer@spglobal-test.local",
      "resource_type": "glossary",
      "resource": "MarketImpactGlossary",
      "expect": {
        "ViewAll": "allow",
        "Create": "allow",
        "EditAll": "allow",
        "EditDescription": "allow",
        "EditCustomFields": "allow",
        "Delete": "notAllow"
